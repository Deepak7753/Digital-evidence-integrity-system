# Digital Evidence Integrity System Evidence Vault Environment Configuration
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=generate-a-secure-random-secret-key-here-for-production-12345

# Database configuration
# For MySQL: mysql+pymysql://username:password@localhost:3306/chainproof_db
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/chainproof_db

# Encryption Configuration
# 32 bytes AES Key (must be exactly 32 bytes for AES-256)
ENCRYPTION_KEY=super-secure-32-byte-encryption-key-for-aes-256

# Mail configuration for verification and alerts
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@deis-vault.local
